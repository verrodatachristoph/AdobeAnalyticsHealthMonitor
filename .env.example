# Supabase — public client (safe in browser bundle, RLS-gated)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server-only. NEVER imported into client code.
# Used by Edge Functions, server actions, and admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron / Edge Function shared secret (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-strong-random-string

# Adobe IMS — server-only. One set per integration; this is for local dev only.
# Production credentials live encrypted in Supabase Vault per-integration.
ADOBE_IMS_CLIENT_ID=
ADOBE_IMS_CLIENT_SECRET=
ADOBE_IMS_ORG_ID=
ADOBE_IMS_TECHNICAL_ACCOUNT_ID=
